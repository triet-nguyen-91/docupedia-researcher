# Docupedia Personal Access Token (PAT)
DOCUPEDIA_PAT=your_personal_access_token_here

# Base URL of your Confluence instance (no trailing slash)
DOCUPEDIA_BASE_URL=https://inside-docupedia.bosch.com/confluence2

# Confluence space key to crawl (e.g. BBM, TEAM, ~username)
SPACE_KEY=YOUR_SPACE_KEY

# Max pages to crawl — set to 0 to crawl ALL pages in the space
MAX_PAGES=0

# Optional: crawl from a specific root page and all its sub-pages.
# Set to a Confluence page ID to crawl that subtree only.
# Leave empty (or remove the line) to crawl the entire SPACE_KEY space.
PAGE_ID=

# Optional: path to the local embedding model directory (for offline machines).
# Run scripts/download_model.py on an internet-connected machine first,
# then copy the project (including data/models/) and set this path.
# Leave empty to download automatically from HuggingFace on first run.
EMBEDDING_MODEL=data/models/multilingual-e5-base

# Seconds of delay between API batch requests (default: 0.2).
# Increase if the Confluence server returns 429 / rate-limit errors.
REQUEST_DELAY=0.2

# Confluence API pagination batch size — max supported value is 100.
CRAWL_BATCH_SIZE=100

# Number of parallel worker threads for per-page processing.
# Increase on machines with more CPU cores / fast network; decrease if
# you see memory pressure or Confluence rate-limit errors.
CRAWL_WORKERS=4

# ---------------------------------------------------------------------------
# Optional: Chat UI (Chainlit + Ollama)
# Only needed if you run: chainlit run chat_ui/app.py
# Install: pip install -r requirements-chat.txt
# Docs:    see README.md → "Optional: Chat UI"
# ---------------------------------------------------------------------------

# Ollama model to use for generating answers.
# Pull the model first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Base URL of the local Ollama server (default port 11434).
OLLAMA_BASE_URL=http://localhost:11434

# Number of ChromaDB chunks to retrieve per query (more = richer context, slower LLM).
CHAT_TOP_K=6

# Number of candidate chunks to fetch before reranking and deduplicating.
CHAT_SEARCH_K=14

# Max total context size sent to the LLM, in characters.
CHAT_MAX_CONTEXT_CHARS=7000

# Max prior chat turns kept for follow-up questions.
CHAT_MAX_HISTORY_TURNS=2

# Limit repeated chunks from the same page to improve source diversity.
CHAT_MAX_CHUNKS_PER_PAGE=2

# Ollama generation settings tuned for grounded RAG answers.
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=768
